        "ch6-6.1-q1"
      ]
    },
    {
      "id": "6.2",
      "title": "具身智能与物理 Agent",
      "subtitle": "机器人 + LLM",
      "estimatedMinutes": 15,
      "difficulty": 2,
      "objectives": [
        "了解具身智能概念",
        "理解机器人+LLM 结合",
        "了解代表项目"
      ],
      "content": [
        {
          "type": "knowledgePoint",
          "title": "具身智能（Embodied AI）",
          "content": [
            {
              "type": "paragraph",
              "text": "**具身智能**是将 LLM 的推理能力与物理机器人的感知执行能力结合，让 AI 能在物理世界中行动。这是从数字 Agent 到物理 Agent 的跨越。"
            },
            {
              "type": "table",
              "data": {
                "headers": [
                  "项目",
                  "公司",
                  "特点"
                ],
                "rows": [
                  [
                    "**Figure 01/02**",
                    "Figure AI",
                    "人形机器人 + OpenAI 模型"
                  ],
                  [
                    "**Optimus**",
                    "Tesla",
                    "人形机器人，自主任务执行"
                  ],
                  [
                    "**RT-2**",
                    "Google DeepMind",
                    "视觉-语言-动作模型"
                  ],
                  [
                    "**GR-1**",
                    "字节跳动",
                    "人形机器人通用模型"
                  ]
                ]
              }
            },
            {
              "type": "callout",
              "variant": "tip",
              "title": "Sim-to-Real",
              "text": "具身智能核心挑战是 Sim-to-Real（仿真到现实）：在仿真环境中训练，迁移到真实世界。差距（reality gap）是主要难题。"
            }
          ]
        }
      ],
      "exercises": [
        {
          "title": "调研具身智能项目",
          "description": "选择一个具身智能项目深入调研。",
