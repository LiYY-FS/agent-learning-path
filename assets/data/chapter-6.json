  "sections": [
    {
      "id": "6.1",
      "title": "Agent OS 与 Agent 操作系统",
      "subtitle": "理解 Agent OS 愿景",
      "estimatedMinutes": 15,
      "difficulty": 3,
      "objectives": [
        "理解 Agent OS 概念",
        "了解探索项目",
        "理解对开发者的意义"
      ],
      "content": [
        {
          "type": "knowledgePoint",
          "title": "Agent OS 概念",
          "content": [
            {
              "type": "paragraph",
              "text": "**Agent OS** 是为 AI Agent 提供标准化运行环境的操作系统，类似传统 OS 对应用程序的作用。它管理 Agent 的资源（模型、工具、数据）、调度（任务队列）、通信（Agent 间消息）、安全（权限隔离）。"
            },
            {
              "type": "table",
              "data": {
                "headers": [
                  "项目",
                  "机构",
                  "特点"
                ],
                "rows": [
                  [
                    "**AIOS**",
                    "Rutgers University",
                    "学术原型，Agent 调度与资源管理"
                  ],
                  [
                    "**AgentOS**",
                    "开源社区",
                    "模块化 Agent 运行时"
                  ],
                  [
                    "**Microsoft Agent Framework**",
                    "微软",
                    "统一多 Agent 运行时（AutoGen 进入维护模式）"
                  ]
                ]
              }
            },
            {
              "type": "callout",
              "variant": "tip",
              "title": "2026 现实：编码 Agent 即「软件 Agent OS」",
              "text": "2026 年最落地的 Agent OS 形态是 agentic 编码平台：Claude Code（终端优先、可并行子 Agent）、OpenAI Codex（云端沙箱、异步并行任务）、Google Antigravity（Google 的 agentic 开发平台，搭配 Gemini 3.5）。它们统一了「模型 + 工具 + 沙箱 + 文件系统 + 多 Agent 编排」，让 Agent 在受控环境中自主写代码、跑命令、修 Bug。"
            },
            {
              "type": "callout",
              "variant": "info",
              "title": "与传统 OS 的差异",
              "text": "传统 OS 管理 CPU/内存/磁盘等物理资源；Agent OS 管理模型/工具/数据等 AI 资源。Agent OS 还需处理概率性执行、自然语言接口等新挑战。"
            }
          ]
        }
      ],
      "exercises": [
        {
          "title": "调研 Agent OS 项目",
          "description": "调研 AIOS 或 AgentOS 项目，总结其架构和特点。",
          "hints": "关注资源管理和调度机制"
        }
      ],
      "resources": [
        {
          "type": "paper",
          "title": "AIOS: AI Agent Operating System",
          "url": "https://arxiv.org/abs/2403.16971"
        }
      ],
